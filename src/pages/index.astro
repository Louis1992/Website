---
import Layout from '../layouts/Layout.astro';
import HeaderLeadGenies from '../components/leadgenies/HeaderLeadGenies.tsx';
import HeroLeadGeniesv2 from '../components/leadgenies/HeroLeadGeniesv2.tsx';
import TrustSection from '../components/leadgenies/TrustSection.tsx';
import AppFeatureTabs from '../components/leadgenies/AppFeatureTabs.tsx';
import LeistungenSection from '../components/leadgenies/LeistungenSection.tsx';
import HowItWorksSectionV5 from '../components/leadgenies/HowItWorksSectionV5.tsx';
import CaseStudiesSection from '../components/leadgenies/CaseStudiesSection.tsx';
import ROICalculatorSection from '../components/leadgenies/ROICalculatorSection.tsx';
import GuaranteeTempSection from '../components/leadgenies/GuaranteeTempSection.tsx';
import FAQSection from '../components/leadgenies/FAQSection.tsx';
import PricingSection from '../components/leadgenies/PricingSection.tsx';
import ContactSection from '../components/leadgenies/ContactSection.tsx';
import FooterSection from '../components/leadgenies/FooterSection.tsx';
import StickyMobileCTA from '../components/leadgenies/StickyMobileCTA.tsx';

// Language for this page
const lang = 'de';

// Page metadata (German)
const pageTitle = "LeadGenies - Qualifizierte B2B-Termine durch professionelle Kaltakquise";
const pageDescription = "Wir übernehmen Ihre Kaltakquise — mit eigenem SDR-Team, eigener App und 54.000+ B2B-Kontakten. Qualifizierte Termine ab dem ersten Monat.";

// VideoObject Schema for SEO
const videoSchema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": "LeadGenies B2B Kaltakquise Service",
  "description": "Professionelle B2B-Telemarketing-Experten für Ihren skalierbaren Vertrieb",
  "thumbnailUrl": "https://syntra-eu.fra1.cdn.digitaloceanspaces.com/leadgenies/video-poster-desktop.jpg",
  "uploadDate": "2025-01-01",
  "contentUrl": "https://syntra-eu.fra1.cdn.digitaloceanspaces.com/leadgenies/Louis-desktop.mp4",
  "embedUrl": "https://www.leadgenies.de/",
  "duration": "PT30S"
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  type="LocalBusiness"
  lang={lang}
>
  <!-- VideoObject Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} slot="head" />
  <HeaderLeadGenies lang={lang} client:load />

  <main class="relative" style="margin: 0; padding: 0; overflow-x: hidden; width: 100%;">
    <!-- SEO H1 (hidden but crawlable) -->
    <h1 class="sr-only">LeadGenies - Qualifizierte B2B-Termine durch professionelle Kaltakquise</h1>

    <!-- 1. Hero Section with App Dashboard Preview -->
    <section id="hero">
      <HeroLeadGeniesv2 lang={lang} client:load />
    </section>

    <!-- 2. Trust Section with Animated Stats + Reviews -->
    <TrustSection lang={lang} client:idle />

    <!-- 3. App Showcase (Interactive Feature Tabs) -->
    <AppFeatureTabs lang={lang} client:idle />

    <!-- 4. Leistungen (What's Included) -->
    <LeistungenSection lang={lang} client:idle />

    <!-- 5. How It Works -->
    <section id="how-it-works">
      <HowItWorksSectionV5 lang={lang} client:idle />
    </section>

    <!-- 6. Case Studies -->
    <section id="case-studies">
      <CaseStudiesSection lang={lang} client:idle />
    </section>

    <!-- 7. ROI Calculator -->
    <section id="roi-calculator">
      <ROICalculatorSection lang={lang} client:idle />
    </section>

    <!-- 8. Pricing (Caller-based) -->
    <section id="pricing">
      <PricingSection lang={lang} client:idle />
    </section>

    <!-- 9. Guarantee -->
    <section id="guarantee">
      <GuaranteeTempSection lang={lang} client:idle />
    </section>

    <!-- 10. FAQ -->
    <FAQSection lang={lang} client:idle />

    <!-- 11. Contact -->
    <ContactSection lang={lang} client:idle />
  </main>

  <!-- Footer -->
  <FooterSection lang={lang} client:load />

  <!-- Sticky Mobile CTA -->
  <StickyMobileCTA client:idle />
</Layout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
